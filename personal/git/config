[alias]
a = add
d = diff
l = log
lo = log --oneline
ch = checkout
c = commit
cm = commit -m
b = branch
cl = clone
ps = push
pl = pull
rb = rebase -i
r = remote
s = status

[clone]
recurseSubmodules = true

[filter "lfs"]
process = git-lfs filter-process
required = true
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f

[init]
defaultBranch = main

[rebase]
autoStash = true

[submodule]
recurse = true

[url "git@github.com:"]
insteadOf = https://github.com/

[user]
email = mail@erazemk.com
name = Erazem Kokot
