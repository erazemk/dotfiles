#!/usr/bin/env bash
# UserPromptSubmit hook: /split
#
# Forks the current Claude Code session into a NEW Ghostty tab, entirely without
# a model turn. When the submitted prompt starts with `/split`, this hook forks
# the session and blocks the prompt (decision: block) so nothing reaches the
# model. Any other prompt passes through untouched.
#
#   /split                 fork and wait for input in the new tab
#   /split <directive...>  fork and send the directive as the fork's first prompt
#
# The fork uses `claude --resume <id> --fork-session`, so the current session
# (this tab) is never modified — it just keeps running. Requires Ghostty on
# macOS with macos-applescript = true (osascript + Ghostty's AppleScript API).

set -euo pipefail

input="$(cat)"

# jq is required to read the hook payload; without it, pass the prompt through.
if ! command -v jq >/dev/null 2>&1; then
  exit 0
fi

prompt="$(jq -r '.prompt // ""' <<<"$input")"

# Only act on prompts that start with `/split` (bare or followed by whitespace).
# Everything else is a normal prompt — let it through with no model interference.
if [[ ! "$prompt" =~ ^/split([[:space:]]|$) ]]; then
  exit 0
fi

block() { # reason -> emit block decision (exit 0 so JSON is processed), no model turn
  jq -n --arg r "$1" '{decision: "block", reason: $r}'
  exit 0
}

session_id="$(jq -r '.session_id // ""' <<<"$input")"
cwd="$(jq -r '.cwd // ""' <<<"$input")"
[[ -z "$session_id" ]] && block "split: no session_id in hook payload — cannot fork."
[[ -z "$cwd" ]] && cwd="$PWD"

# Directive = everything after the leading `/split`, trimmed of surrounding space.
directive="${prompt#/split}"
directive="${directive#"${directive%%[![:space:]]*}"}"  # ltrim
directive="${directive%"${directive##*[![:space:]]}"}"   # rtrim

# Build the fork command. A directive is passed as a single positional prompt so
# the fork submits it on boot; with none, the tab just waits. printf %q escapes it.
if [[ -n "$directive" ]]; then
  cmd="claude --resume ${session_id} --fork-session $(printf %q "$directive")"
else
  cmd="claude --resume ${session_id} --fork-session"
fi

# Escape for embedding in AppleScript string literals: backslash then quote.
esc() { local s="${1//\\/\\\\}"; printf '%s' "${s//\"/\\\"}"; }
as_cmd="$(esc "$cmd")"
as_cwd="$(esc "$cwd")"

# Feed the command as typed input to a fresh login shell (full PATH), rather than
# exec'ing it directly, so `claude` resolves on PATH. `new tab in front window`
# lands the fork in the current window as a tab, leaving this session in place.
if err="$(osascript 2>&1 <<APPLESCRIPT
tell application "Ghostty"
  set cfg to new surface configuration
  set initial working directory of cfg to "${as_cwd}"
  set initial input of cfg to "${as_cmd}" & linefeed
  new tab in front window with configuration cfg
end tell
APPLESCRIPT
)"; then
  if [[ -n "$directive" ]]; then
    block "✓ split: forked into a new tab with directive — this session is untouched."
  else
    block "✓ split: forked into a new tab — this session is untouched."
  fi
else
  block "split: failed to open Ghostty tab: ${err}"
fi
