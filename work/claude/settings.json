{
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "awsAuthRefresh": "aws sso login --profile claude",
  "enabledPlugins": {
    "airsync@erazemk": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "global.anthropic.claude-fable-5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "global.anthropic.claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "global.anthropic.claude-sonnet-5",
    "AWS_PROFILE": "claude",
    "AWS_REGION": "us-east-1",
    "CLAUDE_AFK_TIMEOUT_MS": "86400000",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "0.25",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    },
    "erazemk": {
      "autoUpdate": true,
      "source": {
        "repo": "erazemk/dotfiles",
        "source": "github"
      }
    }
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/reflection",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/reflection",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  },
  "includeGitInstructions": false,
  "model": "sonnet",
  "outputStyle": "Concise",
  "permissions": {
    "additionalDirectories": [
      "~/DevRev"
    ],
    "defaultMode": "auto",
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode"
    ]
  },
  "showThinkingSummaries": true,
  "spinnerTipsEnabled": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "teammateMode": "in-process",
  "theme": "auto",
  "wheelScrollAccelerationEnabled": false
}
