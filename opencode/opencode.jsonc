{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true,
  },
  "lsp": {},
  "formatter": {},
  "permission": {
    "datadog_*": "deny",
    "devrev_*": "deny",
    "slack_*": "deny",
    "notion_*": "deny",
    "external_directory": {
      "~/DevRev/**": "allow",
      "~/Personal/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.local/share/go/pkg/mod/**": "allow",
      "~/.config/dotfiles/opencode/**": "allow",
      "~/.cache/sidekick/cache/go/mod/**": "allow",
    }
  },
  "mcp": {
    "auggie": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.augmentcode.com/mcp"
    },
    "datadog": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
    },
    "devrev": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.devrev.ai/mcp/v1",
      "headers": {
        "Authorization": "Bearer {env:DEVREV_API_KEY}"
      }
    },
    "notion": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.notion.com/mcp"
    },
    "slack": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "redirectUri": "http://localhost:3118/callback"
      }
    },
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "permission": {
        "devrev_*": "allow",
        "notion_notion-search": "allow",
        "notion_notion-fetch": "allow",
        "notion_notion-get-comments": "allow",
        "notion_notion-get-users": "allow",
        "notion_notion-create-pages": "allow",
        "notion_notion-update-page": "allow",
      }
    },
    "build": {
      "model": "openai/gpt-5.4",
      "permission": {
        "devrev_*": "allow",
        "notion_notion-search": "allow",
        "notion_notion-fetch": "allow",
        "notion_notion-get-comments": "allow",
        "notion_notion-get-users": "allow",
        "notion_notion-create-pages": "allow",
        "notion_notion-update-page": "allow",
      }
    },
    "general": {
      "model": "openai/gpt-5.4-mini",
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
    },
    "compaction": {
      "model": "openai/gpt-5.5",
    }
  },
}
