{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true,
  },
  "lsp": {},
  "formatter": {},
  "permission": {
    "datadog_*": "deny",
    "devrev_*": "deny",
    "slack_*": "deny",
    "notion_*": "deny",
    "external_directory": {
      "~/DevRev/**": "allow",
      "~/Personal/**": "allow",
      "/var/folders/kl/**": "allow",
      "~/.cache/sidekick/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.local/share/go/pkg/mod/**": "allow",
      "~/.config/dotfiles/opencode/**": "allow",
      "~/.local/share/opencode/worktree/**": "allow",
    }
  },
  "mcp": {
    "auggie": {
      "type": "local",
      "enabled": true,
      "command": [
        "auggie",
        "--mcp",
        "--mcp-auto-workspace",
      ]
    },
    "datadog": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
    },
    "devrev": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.devrev.ai/mcp/v1",
      "headers": {
        "Authorization": "Bearer {env:DEVREV_API_KEY}"
      }
    },
    "engram": {
      "type": "local",
      "command": [
        "/opt/homebrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true
    },
    "slack": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "redirectUri": "http://localhost:3118/callback"
      }
    },
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "build": {
      "model": "openai/gpt-5.4"
    },
    "general": {
      "model": "openai/gpt-5.4-mini"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    }
  },
  // "provider": {
