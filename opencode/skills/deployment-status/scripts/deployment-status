#!/usr/bin/env bash
# deployment-status
#
# Shows deployed AWS Lambda commit versions across known environments and
# regions for a service such as airdrop-devrev-loader.
#
# Usage:
#   deployment-status [--profile PROFILE] [--region REGION] [--format COLUMNS] [--debug] <lambda-function-name>
#   deployment-status --help
#
# Output:
#   - TTY: aligned table
#   - Non-TTY: JSON array
#
# Examples:
#   deployment-status airdrop-devrev-loader
#   deployment-status --region us-east-1 airdrop-devrev-loader
#   deployment-status --region ap-northeast-1 airdrop-devrev-loader
#   deployment-status --format 'Env,Region,Behind Main,Title' airdrop-devrev-loader

set -euo pipefail

usage() {
  printf 'Usage: %s [--profile PROFILE] [--region REGION] [--format COLUMNS] [--debug] <lambda-function-name>\n' "${0##*/}" >&2
  printf '       %s --help\n' "${0##*/}" >&2
  printf '\n' >&2
  printf 'Examples:\n' >&2
  printf '  %s airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --region us-east-1 airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --region ap-northeast-1 airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --profile prod airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --profile prodjp airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --profile prod --region ap-south-1 airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --profile prodjp --region ap-northeast-1 airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --format '\''Env,Region,Behind Main,Title'\'' airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --format '\''Commit,Title,Env'\'' --region us-east-1 airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '  %s --debug airdrop-devrev-loader\n' "${0##*/}" >&2
  printf '\n' >&2
  printf 'Defaults:\n' >&2
  printf '  --region ap-northeast-1 implies --profile prodjp when --profile is omitted\n' >&2
  printf '  --profile prodjp implies --region ap-northeast-1 when --region is omitted\n' >&2
}

debug=0
region=''
profile=''
format_spec=''
function_name=''
output_is_tty=0
selected_columns=('Env' 'Region' 'Deploy/Commit Date' 'Commit' 'Behind Main' 'Title')

if [ -t 1 ]; then
  output_is_tty=1
fi

trim_spaces() {
  local value=$1

  value=${value#"${value%%[![:space:]]*}"}
  value=${value%"${value##*[![:space:]]}"}
  printf '%s' "$value"
}

canonicalize_column() {
  case "$1" in
    [Ee][Nn][Vv])
      printf 'Env'
      ;;
    [Rr][Ee][Gg][Ii][Oo][Nn])
      printf 'Region'
      ;;
    [Dd][Ee][Pp][Ll][Oo][Yy]/[Cc][Oo][Mm][Mm][Ii][Tt][[:space:]][Dd][Aa][Tt][Ee]|[Dd][Ee][Pp][Ll][Oo][Yy][[:space:]][Dd][Aa][Tt][Ee])
      printf 'Deploy/Commit Date'
      ;;
    [Cc][Oo][Mm][Mm][Ii][Tt])
      printf 'Commit'
      ;;
    [Bb][Ee][Hh][Ii][Nn][Dd][[:space:]][Mm][Aa][Ii][Nn])
      printf 'Behind Main'
      ;;
    [Tt][Ii][Tt][Ll][Ee])
      printf 'Title'
      ;;
    *)
      return 1
      ;;
  esac
}

parse_format_columns() {
  local raw_columns=()
  local raw_column
  local column

  IFS=',' read -r -a raw_columns <<< "$format_spec"
  if [ ${#raw_columns[@]} -eq 0 ]; then
    printf 'Invalid --format value: %s\n' "$format_spec" >&2
    usage
    exit 64
  fi

  selected_columns=()
  for raw_column in "${raw_columns[@]}"; do
    column=$(trim_spaces "$raw_column")
    if [ -z "$column" ]; then
      printf 'Invalid --format value: %s\n' "$format_spec" >&2
      usage
      exit 64
    fi

    if ! column=$(canonicalize_column "$column"); then
      printf 'Unknown column in --format: %s\n' "$raw_column" >&2
      usage
      exit 64
    fi

    selected_columns+=("$column")
  done
}

while [ $# -gt 0 ]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --debug)
      debug=1
      ;;
    --region)
      if [ $# -lt 2 ]; then
        usage
        exit 64
      fi
      region=$2
      shift
      ;;
    --profile)
      if [ $# -lt 2 ]; then
        usage
        exit 64
      fi
      profile=$2
      shift
      ;;
    --format)
      if [ $# -lt 2 ]; then
        usage
        exit 64
      fi
      format_spec=$2
      shift
      ;;
    --*)
      usage
      exit 64
      ;;
    *)
      if [ -z "$function_name" ]; then
        function_name=$1
      else
        usage
        exit 64
      fi
      ;;
  esac
  shift
done

if [ -z "$function_name" ]; then
  usage
  exit 64
fi

if [ -n "$format_spec" ]; then
  parse_format_columns
fi

if ! command -v aws >/dev/null 2>&1; then
  printf 'aws is required.\n' >&2
  exit 1
fi

if ! command -v gh >/dev/null 2>&1; then
  printf 'gh is required. Run gh auth login, then retry.\n' >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  printf 'jq is required.\n' >&2
  exit 1
fi

selected_columns_json=''
if [ "$output_is_tty" -eq 0 ]; then
  selected_columns_json=$(jq -cn '$ARGS.positional' --args "${selected_columns[@]}")
fi

debug_log() {
  if [ "$debug" -eq 1 ]; then
    printf 'debug: %s\n' "$*" >&2
  fi
}

join_by() {
  local delimiter=$1
  shift
  local first=1
  local item

  for item in "$@"; do
    if [ "$first" -eq 1 ]; then
      printf '%s' "$item"
      first=0
    else
      printf '%s%s' "$delimiter" "$item"
    fi
  done
}

run_lambda_get_function() {
  local run_profile=${1:-}
  local run_region=${2:-}
  local output
  local status
  local cmd=(aws lambda get-function --function-name "$function_name" --output json)

  if [ -n "$run_region" ]; then
    cmd+=(--region "$run_region")
  fi

  if [ -n "$run_profile" ]; then
    cmd+=(--profile "$run_profile")
  fi

  if output=$("${cmd[@]}" 2>&1); then
    status=0
  else
    status=$?
  fi

  if [ "$status" -ne 0 ] && [[ "$output" == *'Error when retrieving token from sso: Token has expired and refresh failed'* ]]; then
    local login_profile=${run_profile:-default}
    debug_log "refreshing SSO for profile ${login_profile}"

    if output=$(aws sso login --profile "$login_profile" 2>&1); then
      status=0
    else
      status=$?
    fi

    if [ "$status" -ne 0 ]; then
      printf '%s' "$output"
      return "$status"
    fi

    if output=$("${cmd[@]}" 2>&1); then
      status=0
    else
      status=$?
    fi
  fi

  printf '%s' "$output"
  return "$status"
}

extract_image_tag() {
  local image_uri=$1
  local image_tag=${image_uri##*:}

  if [[ "$image_tag" =~ (v?[0-9a-f]{7,40})$ ]]; then
    printf '%s' "${BASH_REMATCH[1]#v}"
    return 0
  fi

  printf '%s' "$image_tag"
}

gh_api() {
  gh api "$1"
}

if ! gh_api "repos/devrev/${function_name}" >/dev/null 2>&1; then
  printf 'Repository devrev/%s was not found or is not accessible.\n' "$function_name" >&2
  exit 1
fi

format_commit_info() {
  local deployed_sha=$1
  local short_sha message title compare_status ahead_by behind_text commit_date commit_fields

  commit_fields=$(gh api "repos/devrev/${function_name}/commits/${deployed_sha}" --jq '[.sha[0:8], .commit.committer.date, (.commit.message | split("\n")[0])] | @tsv' 2>/dev/null || true)
  if [ -z "$commit_fields" ]; then
    printf '%s\t%s\t%s\t%s' "$deployed_sha" '-' 'commit metadata unavailable' '? behind'
    return 0
  fi

  IFS=$'\t' read -r short_sha commit_date message _ <<< "$commit_fields"
  commit_date=${commit_date%%T*}
  title=$message
  if ! compare_status=$(gh api "repos/devrev/${function_name}/compare/${deployed_sha}...main" --jq '.status' 2>/dev/null); then
    printf '%s\t%s\t%s\t%s' "$short_sha" "$commit_date" "$title" '? behind'
    return 0
  fi

  ahead_by=$(gh api "repos/devrev/${function_name}/compare/${deployed_sha}...main" --jq '.ahead_by')

  case "$compare_status" in
    identical)
      behind_text='0 behind'
      ;;
    ahead)
      behind_text=$(printf '%s behind' "$ahead_by")
      ;;
    diverged)
      behind_text=$(printf '%s behind' "$ahead_by")
      ;;
    behind)
      behind_text='0 behind'
      ;;
    *)
      behind_text='? behind'
      ;;
  esac

  printf '%s\t%s\t%s\t%s' "$short_sha" "$commit_date" "$title" "$behind_text"
}

column_width() {
  case "$1" in
    'Env')
      printf '10'
      ;;
    'Region')
      printf '15'
      ;;
    'Deploy/Commit Date')
      printf '25'
      ;;
    'Commit')
      printf '10'
      ;;
    'Behind Main')
      printf '13'
      ;;
    'Title')
      printf '40'
      ;;
  esac
}

column_value() {
  local column=$1
  local env_label=$2
  local region_value=$3
  local deploy_commit_date=$4
  local commit_hash=$5
  local behind_main=$6
  local title=$7

  case "$column" in
    'Env')
      printf '%s' "$env_label"
      ;;
    'Region')
      printf '%s' "$region_value"
      ;;
    'Deploy/Commit Date')
      printf '%s' "$deploy_commit_date"
      ;;
    'Commit')
      printf '%s' "$commit_hash"
      ;;
    'Behind Main')
      printf '%s' "$behind_main"
      ;;
    'Title')
      printf '%s' "$title"
      ;;
  esac
}

print_row() {
  local env_label=$1
  local region_value=$2
  local deploy_date=$3
  local commit_hash=$4
  local behind_main=$5
  local title=$6
  local column
  local value
  local display_width
  local index

  if [ "$output_is_tty" -eq 0 ]; then
    jq -cn \
      --argjson columns "$selected_columns_json" \
      --arg env "$env_label" \
      --arg region "$region_value" \
      --arg deploy_commit_date "$deploy_commit_date" \
      --arg commit "$commit_hash" \
      --arg behind_main "$behind_main" \
      --arg title "$title" '
        reduce $columns[] as $column ({};
          . + if $column == "Env" then {"Env": $env}
              elif $column == "Region" then {"Region": $region}
              elif $column == "Deploy/Commit Date" then {"Deploy/Commit Date": $deploy_commit_date}
              elif $column == "Commit" then {"Commit": $commit}
              elif $column == "Behind Main" then {"Behind Main": $behind_main}
              elif $column == "Title" then {"Title": $title}
              else {}
              end
        )'
    return 0
  fi

  for ((index = 0; index < ${#selected_columns[@]}; index++)); do
    column=${selected_columns[$index]}
    value=$(column_value "$column" "$env_label" "$region_value" "$deploy_date" "$commit_hash" "$behind_main" "$title")
    display_width=$(column_width "$column")

    if [ "$index" -lt $((${#selected_columns[@]} - 1)) ]; then
      printf '%-*s  ' "$display_width" "$value"
    else
      printf '%s\n' "$value"
    fi
  done
}

print_header() {
  if [ "$output_is_tty" -eq 0 ]; then
    return 0
  fi

  if [ "$output_is_tty" -eq 1 ]; then
    printf '\033[1m'
    print_row 'Env' 'Region' 'Deploy/Commit Date' 'Commit' 'Behind Main' 'Title'
    printf '\033[0m'
  else
    print_row 'Env' 'Region' 'Deploy/Commit Date' 'Commit' 'Behind Main' 'Title'
  fi
}

format_deployed_at() {
  local updated_at=$1

  if [ "$updated_at" = '-' ] || [ -z "$updated_at" ]; then
    printf '%s' '-'
    return 0
  fi

  updated_at=${updated_at%%.*}
  updated_at=${updated_at%%T*}
  printf '%s' "$updated_at"
}

process_target() {
  local env_label=$1
  local target_profile=$2
  local target_region=$3
  local profile_display=${target_profile:-default}
  local output status image_uri deployed_sha updated_at deployed_at_display commit_info commit_hash commit_date commit_title behind_text deploy_commit_date

  if output=$(run_lambda_get_function "$target_profile" "$target_region"); then
    status=0
  else
    status=$?
  fi

  if [ "$status" -ne 0 ]; then
    if [[ "$output" == *'The config profile ('*') could not be found'* ]]; then
      return 10
    fi

    if [[ "$output" == *'ResourceNotFoundException'* ]]; then
      print_row "$env_label" "${target_region:--}" '- / -' '-' '-' 'not deployed'
      return 0
    fi

    if [ "$debug" -eq 1 ]; then
      printf 'error: aws lambda get-function failed for env=%s profile=%s region=%s\n%s\n' "$env_label" "$profile_display" "${target_region:--}" "$output" >&2
    fi
    return "$status"
  fi

  IFS=$'\t' read -r image_uri updated_at _ <<< "$(printf '%s\n' "$output" | jq -r '[.Code.ImageUri // "", .Configuration.LastModified // "-"] | @tsv')"
  deployed_sha=$(extract_image_tag "$image_uri")
  deployed_at_display=$(format_deployed_at "$updated_at")
  commit_info=$(format_commit_info "$deployed_sha")
  IFS=$'\t' read -r commit_hash commit_date commit_title behind_text <<< "$commit_info"
  deploy_commit_date="$deployed_at_display / $commit_date"
  print_row "$env_label" "${target_region:--}" "$deploy_commit_date" "$commit_hash" "$behind_text" "$commit_title"
}

process_with_fallback() {
  local env_label=$1
  local target_region=$2
  shift 2
  local candidates=("$@")
  local profile_candidate status
  local missing_profiles=()

  for profile_candidate in "${candidates[@]}"; do
    if process_target "$env_label" "$profile_candidate" "$target_region"; then
      status=0
    else
      status=$?
    fi

    if [ "$status" -eq 0 ]; then
      return 0
    fi

    if [ "$status" -eq 10 ]; then
      missing_profiles+=("$profile_candidate")
      continue
    fi

    return "$status"
  done

  if [ "$debug" -eq 1 ] && [ ${#missing_profiles[@]} -eq ${#candidates[@]} ]; then
    printf 'error: no configured AWS profile found for %s in %s (checked: %s)\n' "$env_label" "$target_region" "$(join_by ', ' "${missing_profiles[@]}")" >&2
    return 1
  fi

  return 0
}

ensure_profile_ready() {
  local target_profile=$1
  local target_region=$2
  local output
  local status
  local profile_display=${target_profile:-default}

  if output=$(run_lambda_get_function "$target_profile" "$target_region"); then
    status=0
  else
    status=$?
  fi

  if [ "$status" -eq 0 ]; then
    return 0
  fi

  if [[ "$output" == *'The config profile ('*') could not be found'* ]]; then
    return 10
  fi

  if [[ "$output" == *'ResourceNotFoundException'* ]]; then
    return 0
  fi

  if [ "$debug" -eq 1 ]; then
    printf 'error: aws lambda get-function failed during auth preflight for profile=%s region=%s\n%s\n' "$profile_display" "${target_region:--}" "$output" >&2
  fi

  return "$status"
}

run_buffered_target() {
  local mode=$1
  local env_label=$2
  local target_profile=$3
  local target_region=$4
  local output_file=$5
  local error_file=$6
  local status_file=$7
  local status

  (
    if [ "$mode" = 'fallback' ]; then
      if process_with_fallback "$env_label" "$target_region" "$target_profile" default; then
        status=0
      else
        status=$?
      fi
    else
      if process_target "$env_label" "$target_profile" "$target_region"; then
        status=0
      else
        status=$?
      fi

      if [ "$status" -eq 10 ] && [ -n "$target_profile" ]; then
        printf 'AWS profile %s was not found.\n' "$target_profile" >&2
      fi
    fi

    printf '%s\n' "$status" > "$status_file"
    exit "$status"
  ) >"$output_file" 2>"$error_file" &
}

temp_dir=$(mktemp -d)
cleanup() {
  if [ -n "${temp_dir:-}" ] && [ -d "$temp_dir" ]; then
    rm -rf "$temp_dir"
  fi
}
trap cleanup EXIT

profile_state_file() {
  local profile_key=${1:-default}
  profile_key=${profile_key//[^A-Za-z0-9._-]/_}
  printf '%s/preflight.%s' "$temp_dir" "$profile_key"
}

get_profile_state() {
  local state_file
  state_file=$(profile_state_file "$1")
  if [ -f "$state_file" ]; then
    <"$state_file" tr -d '\n'
  fi
}

set_profile_state() {
  local state_file
  state_file=$(profile_state_file "$1")
  printf '%s\n' "$2" > "$state_file"
}

declare -a pids=()
declare -a output_files=()
declare -a error_files=()
declare -a status_files=()
declare -a queued_modes=()
declare -a queued_envs=()
declare -a queued_profiles=()
declare -a queued_regions=()

start_target() {
  local mode=$1
  local env_label=$2
  local target_profile=$3
  local target_region=$4
  local index=${#pids[@]}
  local output_file="$temp_dir/${index}.out"
  local error_file="$temp_dir/${index}.err"
  local status_file="$temp_dir/${index}.status"

  output_files+=("$output_file")
  error_files+=("$error_file")
  status_files+=("$status_file")

  run_buffered_target "$mode" "$env_label" "$target_profile" "$target_region" "$output_file" "$error_file" "$status_file"
  pids+=("$!")
}

launch_target() {
  queued_modes+=("$1")
  queued_envs+=("$2")
  queued_profiles+=("$3")
  queued_regions+=("$4")
}

launch_known_target() {
  local mode=$1
  local env_label=$2
  local target_profile=$3
  local target_region=$4

  if [ -n "$profile" ] && [ "$profile" != "$target_profile" ]; then
    return 0
  fi

  if [ "$env_label" = 'pre-prod' ] && [ "$profile" = 'prod' ] && [ -z "$region" ]; then
    return 0
  fi

  if [ -n "$region" ] && [ "$region" != "$target_region" ]; then
    return 0
  fi

  launch_target "$mode" "$env_label" "$target_profile" "$target_region"
}

launch_known_target 'fallback' 'dev' 'dev' 'us-east-1'
launch_known_target 'direct' 'qa' 'qa' 'us-east-1'
launch_known_target 'direct' 'qa' 'qa' 'ap-south-1'
launch_known_target 'direct' 'pre-prod' 'prod' 'ap-southeast-1'
launch_known_target 'direct' 'prod' 'prod' 'us-east-1'
launch_known_target 'direct' 'prod' 'prod' 'ap-south-1'
launch_known_target 'direct' 'prod' 'prod' 'ap-southeast-2'
launch_known_target 'direct' 'prod' 'prodjp' 'ap-northeast-1'
launch_known_target 'direct' 'prod' 'prod' 'eu-central-1'

if [ ${#queued_modes[@]} -eq 0 ]; then
  custom_env='custom'
  if [ "$profile" = 'prod' ] && [ "$region" = 'ap-southeast-1' ]; then
    custom_env='pre-prod'
  elif [ -n "$profile" ]; then
    custom_env=$profile
  fi

  launch_target 'direct' "$custom_env" "$profile" "$region"
fi

preflight_status=0
for ((index = 0; index < ${#queued_modes[@]}; index++)); do
  mode=${queued_modes[$index]}
  target_profile=${queued_profiles[$index]}
  target_region=${queued_regions[$index]}
  preflight_key=''
  dev_state=''
  default_state=''

  if [ "$mode" = 'fallback' ]; then
    dev_state=$(get_profile_state 'dev')
    if [ -z "$dev_state" ]; then
      if ensure_profile_ready 'dev' "$target_region"; then
        set_profile_state 'dev' 'ready'
        dev_state='ready'
      else
        status=$?
        if [ "$status" -eq 10 ]; then
          set_profile_state 'dev' 'missing'
          dev_state='missing'
        else
          preflight_status=$status
          break
        fi
      fi
    fi

    default_state=$(get_profile_state 'default')
    if [ "$dev_state" = 'missing' ] && [ -z "$default_state" ]; then
      if ensure_profile_ready '' "$target_region"; then
        set_profile_state 'default' 'ready'
        default_state='ready'
      else
        status=$?
        if [ "$status" -eq 10 ]; then
          set_profile_state 'default' 'missing'
          default_state='missing'
        else
          preflight_status=$status
          break
        fi
      fi
    fi

    if [ "$debug" -eq 1 ] && [ "$dev_state" = 'missing' ] && [ "$default_state" = 'missing' ]; then
      printf 'error: no configured AWS profile found for dev in %s (checked: dev, default)\n' "$target_region" >&2
      preflight_status=1
      break
    fi

    continue
  fi

  preflight_key=${target_profile:-default}
  if [ -n "$(get_profile_state "$preflight_key")" ]; then
    continue
  fi

  if ensure_profile_ready "$target_profile" "$target_region"; then
    set_profile_state "$preflight_key" 'ready'
    continue
  fi

  status=$?
  if [ "$status" -eq 10 ]; then
    set_profile_state "$preflight_key" 'missing'
    if [ -n "$target_profile" ]; then
      printf 'AWS profile %s was not found.\n' "$target_profile" >&2
    fi
  else
    preflight_status=$status
    break
  fi
done

if [ "$preflight_status" -ne 0 ]; then
  exit "$preflight_status"
fi

for ((index = 0; index < ${#queued_modes[@]}; index++)); do
  mode=${queued_modes[$index]}
  target_profile=${queued_profiles[$index]}

  if [ "$mode" != 'fallback' ] && [ -n "$target_profile" ] && [ "$(get_profile_state "$target_profile")" = 'missing' ]; then
    continue
  fi

  start_target "$mode" "${queued_envs[$index]}" "$target_profile" "${queued_regions[$index]}"
done

overall_status=0
for pid in "${pids[@]}"; do
  if ! wait "$pid"; then
    :
  fi
done

for status_file in "${status_files[@]}"; do
  if [ -s "$status_file" ]; then
    status=$(<"$status_file")
    if [ "$status" -ne 0 ] && [ "$overall_status" -eq 0 ]; then
      overall_status=$status
    fi
  fi
done

if [ "$output_is_tty" -eq 1 ]; then
  print_header
  for output_file in "${output_files[@]}"; do
    if [ -s "$output_file" ]; then
      while IFS= read -r line; do
        printf '%s\n' "$line"
      done < "$output_file"
    fi
  done
else
  first_json_row=1
  printf '[\n'
  for output_file in "${output_files[@]}"; do
    if [ -s "$output_file" ]; then
      while IFS= read -r line; do
        if [ "$first_json_row" -eq 1 ]; then
          first_json_row=0
        else
          printf ',\n'
        fi
        printf '  %s' "$line"
      done < "$output_file"
    fi
  done
  printf '\n]\n'
fi

for error_file in "${error_files[@]}"; do
  if [ -s "$error_file" ]; then
    while IFS= read -r line; do
      printf '%s\n' "$line" >&2
    done < "$error_file"
  fi
done

exit "$overall_status"
