<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.erazemk.env</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>-c</string>
      <string>
        launchctl setenv OPENCODE_ENABLE_EXA true
        launchctl setenv OPENCODE_EXPERIMENTAL_LSP_TOOL true
        launchctl setenv OPENCODE_EXPERIMENTAL_MARKDOWN true
      </string>
    </array>
    <key>RunAtLoad</key>
    <true />
  </dict>
</plist>
