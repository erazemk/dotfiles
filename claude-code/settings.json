{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "eu.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-6-v1[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "eu.anthropic.claude-sonnet-4-6[1m]",
    "AWS_REGION": "eu-central-1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SHELL": "fish",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_EXTRA_USAGE_COMMAND": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "false"
  },
  "model": "opus[1m]",
  "permissions": {
    "additionalDirectories": [
      "~/DevRev",
      "~/Personal"
    ],
    "defaultMode": "bypassPermissions",
    "deny": [
      "EnterPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "ExitPlanMode",
      "NotebookEdit",
      "mcp__datadog__aggregate_events",
      "mcp__datadog__aggregate_rum_events",
      "mcp__datadog__aggregate_spans",
      "mcp__datadog__check_datadog_mcp_setup",
      "mcp__datadog__get_datadog_incident",
      "mcp__datadog__get_datadog_metric_context",
      "mcp__datadog__get_datadog_metric",
      "mcp__datadog__get_datadog_notebook",
      "mcp__datadog__search_datadog_dashboards",
      "mcp__datadog__search_datadog_events",
      "mcp__datadog__search_datadog_hosts",
      "mcp__datadog__search_datadog_incidents",
      "mcp__datadog__search_datadog_metrics",
      "mcp__datadog__search_datadog_monitors",
      "mcp__datadog__search_datadog_notebooks",
      "mcp__datadog__search_datadog_rum_events",
      "mcp__datadog__search_datadog_service_dependencies",
      "mcp__devrev__fetch_object_context",
      "mcp__devrev__get_enhancement",
      "mcp__devrev__get_incident",
      "mcp__devrev__get_mobile_session_data",
      "mcp__devrev__get_org_user",
      "mcp__devrev__get_part",
      "mcp__devrev__get_session_details",
      "mcp__devrev__get_sprint_board",
      "mcp__devrev__get_valid_stage_transitions",
      "mcp__devrev__link_conversation_with_ticket",
      "mcp__devrev__link_incident_with_issue",
      "mcp__devrev__link_incident_with_ticket",
      "mcp__devrev__link_issue_with_issue",
      "mcp__devrev__link_meeting_with_ticket",
      "mcp__devrev__link_ticket_with_issue",
      "mcp__devrev__recall_chats",
      "mcp__notion__notion-create-comment",
      "mcp__notion__notion-create-database",
      "mcp__notion__notion-create-pages",
      "mcp__notion__notion-create-view",
      "mcp__notion__notion-duplicate-page",
      "mcp__notion__notion-get-teams",
      "mcp__notion__notion-get-users",
      "mcp__notion__notion-move-pages",
      "mcp__notion__notion-update-data-source",
      "mcp__notion__notion-update-view",
      "mcp__slack__slack_create_canvas",
      "mcp__slack__slack_read_canvas",
      "mcp__slack__slack_schedule_message",
      "mcp__slack__slack_search_public",
      "mcp__slack__slack_update_canvas"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "bash ~/.claude/statusline.sh",
    "type": "command"
  }
}
