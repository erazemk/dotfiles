{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "env": {
    "AWS_REGION": "eu-central-1",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(find *)",
      "Bash(go *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(make *)",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(rm *)"
    ]
  }
}
