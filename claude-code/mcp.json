{
    "mcpServers": {
        "datadog": {
            "type": "http",
            "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
        },
        "notion": {
            "type": "http",
            "url": "https://mcp.notion.com/mcp"
        },
        "search-current-codebase": {
            "type": "stdio",
            "command": "auggie",
            "args": [
                "--mcp",
                "--mcp-auto-workspace"
            ]
        },
        "search-external-codebases": {
            "type": "http",
            "url": "https://api.augmentcode.com/mcp"
        },
        "devrev": {
            "type": "http",
            "url": "https://api.devrev.ai/mcp/v1",
            "headers": {
                "Authorization": "Bearer ${DEVREV_API_KEY}"
            }
        },
        "granola": {
            "type": "http",
            "url": "https://mcp.granola.ai/mcp"
        },
        "slack": {
            "type": "http",
            "url": "https://mcp.slack.com/mcp",
            "oauth": {
                "clientId": "1601185624273.8899143856786",
                "callbackPort": 3118
            }
        }
    }
}
